# a8-claw local-mode .env example
#
# Copy this file to .env and fill in values for your local environment.
# In production, K8s ConfigMap + Secret populate these directly via the
# pod env (see k8s/sandbox-template.yaml and k8s/secrets-and-config.yaml).
#
# Loading: this fork does NOT auto-source .env at startup. Use one of:
#   1) Shell-source before launching the host process:
#        set -a; source .env; set +a
#        pnpm dev
#   2) dotenv-cli wrapper:
#        pnpm dlx dotenv-cli -e .env -- pnpm dev
#   3) Node's built-in --env-file (Node 20+):
#        NODE_OPTIONS="--env-file=.env" pnpm dev

# ──────────────────────────────────────────────────────────────────────
# Tenant context — REQUIRED (both must be non-empty; tenant-only scoping
# is a security breach per the platform tenant+user invariant).
# In production these come from per-pod env injection by the warm-pool
# allocator at scheduling time. For local dev, use your AgentMesh tenant
# identifier and a user id under that tenant.
# ──────────────────────────────────────────────────────────────────────
TENANT_ID=
USER_ID=

# ──────────────────────────────────────────────────────────────────────
# Main-model routing — RUNTIME_CONTRACT v1.1 §7.1
# "direct" (default for a8-claw, a8-code): main-model traffic goes direct
#   to Anthropic for latency. Requires ANTHROPIC_API_KEY below. Runtime
#   self-reports usage to metering-service after each call.
# "model_manager": main-model traffic goes through Model Manager gateway.
#   No API key in env; MM auto-meters; ~+30ms per call.
# All OTHER model calls (sub-agents, embeddings, OCR, judges, perception
# models) go through Model Manager regardless of this setting.
# ──────────────────────────────────────────────────────────────────────
MAIN_MODEL_ROUTE=direct

# Anthropic API key — REQUIRED when MAIN_MODEL_ROUTE=direct.
# Use your own key for local development. In production this is resolved
# per-tenant + per-user (BYOK) from the platform credential service.
ANTHROPIC_API_KEY=

# Default chat model NAME (env-config; UUID resolved at runtime per route).
# In direct mode the SDK uses this name as-is.
# In model_manager mode the runtime POSTs to {MODEL_MANAGER_URL}/resolve
# to get the endpoint UUID and uses {MODEL_MANAGER_URL}/run/{uuid}.
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────────
# AgentMesh platform service URLs
# Cluster-internal addresses in production; staging-cluster ELBs for
# local development (or local-port-forwarded URLs).
# ──────────────────────────────────────────────────────────────────────
WARP_URL=http://a7467be8f89754f7b80eff560d5e20d0-00b1550d014a24f4.elb.us-west-2.amazonaws.com:8085
MODEL_MANAGER_URL=http://a667db70e77234d45ad009f6ad39ec73-1362220438.us-west-2.elb.amazonaws.com:8000
# TOOL_MANAGER_URL — not used in v1 local mode; native nanoclaw tools
# cover the smoke test. Tool Manager MCP integration ships in a follow-up
# phase (we expose the entire Tool Manager as an MCP endpoint then).
# TOOL_MANAGER_URL=

# ──────────────────────────────────────────────────────────────────────
# Metering self-report — only used when MAIN_MODEL_ROUTE=direct.
# Where the runtime POSTs main-model usage records (fire-and-forget).
# Optional locally — if unset, the runtime logs a warning and skips.
# Production direct-mode deployments MUST set this.
# ──────────────────────────────────────────────────────────────────────
# METERING_USAGE_URL=http://aks-metering-service.aks-metering-apps.svc.cluster.local:8000/v1/usage

# ──────────────────────────────────────────────────────────────────────
# RabbitMQ for mission-queue adapter (Phase 9 — not used in v1 local)
# ──────────────────────────────────────────────────────────────────────
# RABBITMQ_URL=
