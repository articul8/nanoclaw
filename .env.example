# a8-claw local-mode .env example
#
# Copy this file to .env and fill in values for your local environment.
# Or run `./a8-claw configure` for an interactive prompt that writes
# .env for you. In production, K8s ConfigMap + Secret populate these
# directly via the pod env (see k8s/sandbox-template.yaml +
# k8s/secrets-and-config.yaml).
#
# Loading: this fork does NOT auto-source .env at startup. The CLI
# (src/cli.ts) reads .env directly when invoked via ./a8-claw. If you
# bypass the CLI (e.g. running `pnpm dev` directly), source it yourself:
#   set -a; source .env; set +a; pnpm dev

# ──────────────────────────────────────────────────────────────────────
# Tenant context — REQUIRED (both must be non-empty; tenant-only scoping
# is a security breach per the platform tenant+user invariant).
# ──────────────────────────────────────────────────────────────────────
TENANT_ID=
USER_ID=

# ──────────────────────────────────────────────────────────────────────
# Main-model routing — RUNTIME_CONTRACT v1.1 §7.1
# "direct" (default for a8-claw, a8-code): main-model traffic goes direct
#   to the configured provider's base URL for latency. Requires
#   MAIN_MODEL_API_KEY below. Runtime self-reports usage to
#   metering-service after each call.
# "model_manager": main-model traffic goes through Model Manager gateway.
#   No API key in env; MM auto-meters; ~+30ms per call.
# All OTHER model calls (sub-agents, embeddings, OCR, judges, perception
# models) go through Model Manager regardless of this setting.
# ──────────────────────────────────────────────────────────────────────
MAIN_MODEL_ROUTE=direct

# ──────────────────────────────────────────────────────────────────────
# Main-model provider — which LLM provider drives the conversation loop.
# Provider-specific defaults for base URL + model name + key format.
# Container-side SDK selection follows from this (Anthropic SDK for
# anthropic, Google GenAI SDK for google, OpenAI SDK for openai-compat).
#
# Values:
#   anthropic       (default) — Claude family, api.anthropic.com or any
#                                Anthropic-compatible endpoint
#   google          — Google Gemini, generativelanguage.googleapis.com
#   openai-compat   — any OpenAI-API-compatible service: OpenAI itself,
#                     Together, Fireworks, Groq, vLLM-deployed local
#                     models, Ollama OpenAI-compat layer, etc.
# ──────────────────────────────────────────────────────────────────────
MAIN_MODEL_PROVIDER=anthropic

# Provider base URL. Defaults per provider when unset:
#   anthropic     → https://api.anthropic.com
#   google        → https://generativelanguage.googleapis.com
#   openai-compat → https://api.openai.com
# Override here for self-hosted endpoints, proxies, or alternate
# OpenAI-compat services (e.g. https://api.together.xyz/v1).
MAIN_MODEL_BASE_URL=https://api.anthropic.com

# Main-model API key — REQUIRED when MAIN_MODEL_ROUTE=direct.
# Provider-agnostic env name; the runtime maps it to the SDK's expected
# env var per provider (ANTHROPIC_API_KEY / GOOGLE_API_KEY / OPENAI_API_KEY)
# at container spawn. In production this is resolved per-tenant + per-user
# (BYOK) from the platform credential service / vault.
MAIN_MODEL_API_KEY=

# Default chat model NAME (env-config; UUID resolved at runtime in
# model_manager mode). Pick something appropriate for your provider:
#   anthropic     → e.g. claude-sonnet-4-6, claude-opus-4-7
#   google        → e.g. gemini-2.5-flash, gemini-2.0-flash-exp
#   openai-compat → e.g. gpt-4o, meta-llama/Llama-3.3-70B (Together), etc.
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────────
# AgentMesh platform service URLs
# Cluster-internal addresses in production; staging-cluster ELBs for
# local development (or local-port-forwarded URLs).
# ──────────────────────────────────────────────────────────────────────
WARP_URL=http://a7467be8f89754f7b80eff560d5e20d0-00b1550d014a24f4.elb.us-west-2.amazonaws.com:8085
MODEL_MANAGER_URL=http://a667db70e77234d45ad009f6ad39ec73-1362220438.us-west-2.elb.amazonaws.com:8000
# TOOL_MANAGER_URL — not used in v1 local mode; native nanoclaw tools
# cover the smoke test. Tool Manager MCP integration ships in a follow-up
# phase (Tool Manager will be exposed as a proper MCP endpoint).
# TOOL_MANAGER_URL=

# ──────────────────────────────────────────────────────────────────────
# Metering self-report — only used when MAIN_MODEL_ROUTE=direct.
# Where the runtime POSTs main-model usage records (fire-and-forget).
# Optional locally — if unset, the runtime logs a warning and skips.
# Production direct-mode deployments MUST set this.
# ──────────────────────────────────────────────────────────────────────
# METERING_USAGE_URL=http://aks-metering-service.aks-metering-apps.svc.cluster.local:8000/v1/usage

# ──────────────────────────────────────────────────────────────────────
# RabbitMQ for mission-queue adapter (Phase 9 — not used in v1 local)
# ──────────────────────────────────────────────────────────────────────
# RABBITMQ_URL=

# ──────────────────────────────────────────────────────────────────────
# Legacy: ANTHROPIC_API_KEY is honored as a fallback for older .env files
# that pre-date MAIN_MODEL_API_KEY. New configs should use the canonical
# MAIN_MODEL_API_KEY above.
# ANTHROPIC_API_KEY=
